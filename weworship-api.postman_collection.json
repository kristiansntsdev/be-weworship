    {
      "name": "\ud83d\udee1\ufe0f Admin \u2014 Songs",
      "item": [
        {
          "name": "Create song",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Amazing Grace\",\n  \"artist\": [\"Traditional\"],\n  \"base_chord\": \"G\",\n  \"lyrics_and_chords\": \"[G]Amazing [C]grace how [G]sweet the sound\",\n  \"external_links\": \"{\\\"spotify\\\": \\\"https://open.spotify.com/track/xxx\\\", \\\"youtube\\\": \\\"https://youtube.com/watch?v=yyy\\\"}\",\n  \"dmca_takedown\": false,\n  \"dmca_status_notes\": null,\n  \"tag_names\": [\"worship\", \"traditional\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/songs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "songs"
              ]
            },
            "description": "**Required:** `title`, `artist`\n\n**Fields:**\n- `artist`: string or array of strings\n- `external_links`: JSON string `{\"spotify\": \"url\", \"youtube\": \"url\"}`\n- `dmca_takedown`: boolean (default: false)\n- `dmca_status_notes`: free text for DMCA claim notes\n- `tag_names`: auto-creates tags if they don't exist\n\n**Slug** is auto-generated as `{title-slug}-{id}` e.g. `amazing-grace-1`"
          }
        },
        {
          "name": "Update song",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Amazing Grace (Revised)\",\n  \"base_chord\": \"D\",\n  \"dmca_takedown\": true,\n  \"dmca_status_notes\": \"Claimed by publisher XYZ on 2025-01-01\",\n  \"tag_names\": [\"worship\", \"classic\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/songs/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "songs",
                "1"
              ]
            },
